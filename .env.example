# ChaiChat — Environment Configuration
# Copy to .env.local and fill in values.

# JWT secret for signing session tokens (required)
# Generate with: openssl rand -hex 32
JWT_SECRET=

# OpenAI API key for LLM streaming (required)
OPENAI_API_KEY=

# OpenAI API base URL (optional — override for proxied or alternative providers)
# Defaults to https://api.openai.com/v1 if not set
OPENAI_BASE_URL=

# Model selection (optional — defaults to gpt-4)
# Examples: gpt-4, gpt-4o, gpt-4o-mini, gpt-3.5-turbo
OPENAI_MODEL=

# Redis connection URL (required for session persistence)
# Format: redis[s]://[[username][:password]@][host][:port][/db-number]
# Local default (docker-compose): redis://localhost:6379
# To start Redis: docker compose up -d
REDIS_URL=redis://localhost:6379

# Better Stack / Sentry DSN for error tracking (optional)
# Leave empty to disable remote error reporting
SENTRY_DSN=

# Better Stack source token for log forwarding (optional)
# Leave empty to disable remote log forwarding
BETTER_STACK_TOKEN=
